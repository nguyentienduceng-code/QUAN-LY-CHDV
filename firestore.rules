rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is Super Admin
    // TODO: Transition to Custom Claims `request.auth.token.isSuperAdmin == true`
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'nguyentienducbmt123@gmail.com';
    }
    // Helper: Is Workspace Staff/Tenant
    function isOwnerOrStaff(oid) {
      return request.auth != null && (
        request.auth.uid == oid || 
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.ownerId == oid
      );
    }

    // Users Collection
    match /users/{email} {
      // Allow user to read their own data, or workspace owner/staff to read member data
      allow read: if isSuperAdmin() || (request.auth != null && (
        request.auth.token.email == email || 
        isOwnerOrStaff(resource.data.ownerId)
      ));
      // Allow creating profile or workspace owner/staff to create member profile
      allow create: if request.auth != null && (
        request.auth.token.email == email || 
        isOwnerOrStaff(request.resource.data.ownerId)
      );
      // Allow workspace owner/manager to update their staff/tenants
      allow update, delete: if isSuperAdmin() || (
        request.auth != null && isOwnerOrStaff(resource.data.ownerId)
      );
    }

    // Settings Collection
    match /settings/{docId} {
      // docId is the ownerId
      allow read, write: if isSuperAdmin() || isOwnerOrStaff(docId);
    }

    // Rooms Collection
    match /rooms/{docId} {
      allow read: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
      allow create: if isSuperAdmin() || (request.auth != null && isOwnerOrStaff(request.resource.data.ownerId));
      allow update, delete: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
    }

    // Tenants Collection
    match /tenants/{docId} {
      allow read: if isSuperAdmin() || 
                  isOwnerOrStaff(resource.data.ownerId) || 
                  (request.auth != null && request.auth.token.email == resource.data.email);
      allow create: if isSuperAdmin() || (request.auth != null && isOwnerOrStaff(request.resource.data.ownerId));
      allow update, delete: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
    }

    // Contracts Collection
    match /contracts/{docId} {
      allow read: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
      allow create: if isSuperAdmin() || (request.auth != null && isOwnerOrStaff(request.resource.data.ownerId));
      allow update, delete: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
    }

    // Invoices Collection
    match /invoices/{docId} {
      allow read: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
      allow create: if isSuperAdmin() || (request.auth != null && isOwnerOrStaff(request.resource.data.ownerId));
      allow update, delete: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
    }

    // Tickets Collection
    match /tickets/{docId} {
      allow read: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
      allow create: if isSuperAdmin() || (request.auth != null && isOwnerOrStaff(request.resource.data.ownerId));
      allow update, delete: if isSuperAdmin() || isOwnerOrStaff(resource.data.ownerId);
    }
  }
}
